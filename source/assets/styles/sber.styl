body
    font 1.4rem/2rem $inter
    letter-spacing -0.28px
    color #172419

a
    color #128127

.redesign-version
    padding-bottom 74px
    &.home-type
        .h-header
            &.popup-header
                padding 24px 16px
        .h-sitenav
            padding-left 0
            padding-right 0
    &.var2-content-bg
        box-sizing border-box
        min-height 100%
        background #F1F1F1
    .h-header
        box-shadow none
        border-radius 0
        &.popup-header
            h1.fw-600
                font-weight 600
            .today
                color: #128127;
        h1.logo
            margin-left 0
            a
                width 154px
                height 24px
                background-image url(../i/logo_sber.png)
                background-size 154px 24px
            .welcome
                font-size 2.4rem
                line-height 125%
                font-weight 600
                margin-top 40px
                letter-spacing -0.48px
            .sub-welcome
                display block
                font-size 1.6rem
                line-height 2.4rem
                font-weight 400
                margin-top 4px
        .back-to-prev
            display flex
            margin-left -8px
            margin-right 16px
        .ph-arrow-left
            font-size 32px
        .searchbox-filter-wrap.fs-16
            .nav-list ul a
                color inherit
    .auth
        padding-top 0
        color #172419
        .custom-form__field
            input.text
                background rgba(0, 0, 0, 0.04)
                border 1px solid transparent
                padding 16px
                &:focus
                    border-color rgba(18, 129, 39, 0.40)
                    & ~ .toggle-password
                        background-image url("data:image/png;base64,")
            .toggle-password
                width 32px
                height 32px
                background-image none
                background-size 32px 32px
                top 10px
            &.with-float-label
                input.reset
                    top 18px
            &.error
                input.text
                    background rgba(255, 59, 56, 0.08)
        a
            color #172419
            text-decoration underline
        .agree li
            font-size 1.6rem
            line-height 2.4rem
    .checkbox-list-var2
        .checkbox-view i
            font-size 14px
            margin-top 3px
        input.checkbox:checked + .checkbox-view
            background #148F2B
            border-color #148F2B
    .new-app-form-wrap
        padding 0
        textarea
            background rgba(0, 0, 0, 0.04)
            border 1px solid transparent
            height 124px
            padding 24px 16px 16px
            font: 1.6rem $inter
            color #172419
            & + .float-label
                top 6px
            &:focus
                color #172419
                border-color rgba(18, 129, 39, 0.40)
                background rgba(0, 0, 0, 0.04)
            &:focus
            &:not(:placeholder-shown)
                & + .float-label
                    font-size 1.2rem
                    line-height 1.8rem
                    top 6px
            &:not(:placeholder-shown) + .float-label
                color #172419
            &:focus + .float-label
                color #128127
    .new-app-form-footer
        background #fff
        border-top none
        backdrop-filter blur(20px)
        padding-top 8px
        height 74px
    .newapp-title
        font-weight 600
    .newapp-popup-list-choose
        li
            margin 0
    .searchbox
        input.text
            font 1.6rem $inter
            padding-left 36px
            border 1px solid transparent
            &:focus
                border-color rgba(18, 129, 39, .4)
        .ph-magnifying-glass
            font-size 1.6rem
            left 12px
    .radio-list-custom
        .radio-label
            color #172419
        input.radio:checked
            & + .radio-label
                color #172419
                &:before
                    outline-color #148F2B
                    background #148F2B
    .nav-list
        & + .logout
            padding 12px 4px
        a
            padding-left 40px
        svg
            left 4px
    .filter-tags-list
        li
            background rgba(0, 0, 0, 0.04)
            border 1px solid transparent
            border-radius 16px
            padding 7px 11px
            color rgba(23, 36, 25, 0.72)
            &.active
                background-image url("data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAACAAAAAgCAYAAABzenr0AAAAcElEQVR4Ae3WwQmAMBBEUYtYmzAWZSdJB1uykltgDnv7Is5Arvv+RXDzPO8327Nd872CR549st3zSQSGawCPRx7D+Bdw+WR4fDnQIVwDNALAl4NDIgC8jADwOgLA64gKByJAXCN4XCMwnP+x4Od53gMTTribX3SLmgAAAABJRU5ErkJggg==")
                background-color #D0E9D5
                border-color rgba(18, 129, 39, 0.40)
                padding-left 28px
                color #083911

.radio-list-custom__title
    font-size 1.4rem
    line-height 2rem
    margin 0 0 8px

.custom-form__field
    input.text
        background rgba(0, 0, 0, 0.04)
        border 1px solid transparent
        padding 16px
        height 52px
        font 1.6rem $inter
        text-align left
        &:focus
            border-color rgba(18, 129, 39, 0.40)
            background rgba(0, 0, 0, 0.04)
    textarea
        background rgba(0, 0, 0, 0.04)
        border 1px solid transparent
        height 124px
        padding 28px 16px 16px
        font: 1.6rem $sinter
        text-align left
        & + .float-label
            top 6px
        &:focus
            color #172419
            border-color rgba(18, 129, 39, 0.40)
            background rgba(0, 0, 0, 0.04)
    &.with-float-label
        position relative
        input.text
            &:focus
            &:not(:placeholder-shown)
                padding-top 22px
                padding-bottom 8px
                & + .float-label
                    font-size 1.2rem
                    line-height 1.8rem
                    top 4px
            &:not(:placeholder-shown) + .float-label
                color #172419
            &:focus + .float-label
                color #128127
            &:focus ~ input.reset
                background url("data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAACAAAAAgCAQAAADZc7J/AAAAkElEQVR42u2USwrAIAxEPWpuoheQObKlSC225tsunXXeI+iQlHb+TaVKH2YqoaEhSzjyOcMo0AWCouNo4HZAkRQDL9KKrMKE8wozvla48LfCjc+KED4pYvhDUULFHssr7dTxiOJ+OrmdKq4X3NR5l2L972YFXxuTQm6dqqik1eZSyBepGNrJXiSCelQtMzvOHJuWALADA3RDAAAAAElFTkSuQmCC") 0 0 no-repeat
                background-size 16px 16px
                right 56px
        textarea
            & + .float-label
                top 6px
            &:focus
            &:not(:placeholder-shown)
                & + .float-label
                    font-size 1.2rem
                    line-height 1.8rem
                    top 4px
            &:not(:placeholder-shown) + .float-label
                color #172419
        .float-label
            font-size 1.6rem
            line-height 2.4rem
            color #172419
            position absolute
            top 14px
            left 16px
            transition all .175s
            pointer-events none
    &.with-btn
        padding-top 16px
        padding-bottom 0

.custom-form__field-switch
    label
        padding-left 52px
        color #172419
        .switcher
            background rgba(0, 0, 0, 0.40)
            &:after
                width 16px
                height 16px
                top 4px
                left 4px
    input.checkbox:checked
        & + .switcher
            background #148F2B
            &:after
                right 4px

.custom-form__field-inn
    &:last-child
        flex-grow 0
.custom-form__field-del
    width 40px
    height 100%
    font-size 1.6rem
    position relative
    .ph-x
        top 50%
        right auto
        left 50%
        transform translate(-50%, -50%)

.custom-form__field-link-add
    margin 14px 0
    font-weight 500

.custom-form__field-avatar
    width 96px
    height 96px
    border-radius 24px
    background rgba(0, 0, 0, 0.04)
    margin 0 auto
    display flex
    align-items center
    justify-content center
    position relative
    .ph-camera
        font-size 32px
        opacity .72
    img
        display block
        width 100%
        height 100%
        object-fit cover
        position absolute
        top 0
        left 0
        border-radius 24px
.btn
    border-radius 16px
    background #148F2B
    font 500 1.6rem/2.4rem $inter
    color #fff
    padding 12px
    &.gray
        background rgba(0, 0, 0, 0.12)
        color #172419
button.btn
    font-family $inter

.popup-wrap
    &.modal-popup
        padding-top 64px
.modal-popup
    .popup-header
        min-height 64px
    .popup-inner
        max-height calc(100% - 64px)
        border-radius 24px 24px 0 0
.popup-closer
    width 40px
    height 40px
    border-radius 999px
    background rgba(0, 0, 0, 0.04)
    font-size 1.6rem
    .ph
        opacity .48

.popup-footer
    padding 0
    background rgba(255, 255, 255, 0.72)
    backdrop-filter blur(20px)
    .btns-block
        .btn+.btn
            margin-top 0
.popup-footer-inner
    padding-top 8px
    padding-bottom 24px
.popup-footer_title
    font-size 1.6rem
    line-height 2.4rem
    text-align center
    margin 0 0 8px

.h-footer
    border-top none
    height 74px

.foot-nav
    padding 0 0 8px
    li
        height 66px
        font-size 1.1rem
        line-height 1.6rem
        letter-spacing -0.22px
        &.other
            svg
                top 10px
        &.add
            background #148F2B
        &.active
            a
                color #128127
            svg
                path
                    fill #148F2B
                    fill-opacity 1
    a
        color #172419
    svg
        top 10px
        path
            fill #172419
            fill-opacity 0.72

.h-content-round-wrap
    display flex
    flex-direction column
    height 100%
.b-content-round-item
    background #fff
    border-radius 24px
    margin 0 0 8px
    padding 16px 0
    position relative
    &:after
        display block
        content ""
        width 100%
        height 56px
        background #F1F1F1
        position absolute
        bottom -32px
        left 0
        z-index -1
    &:first-child
        border-radius 0 0 24px 24px
    &:last-child
        border-radius 24px 24px 0 0
        margin 0
        flex-grow 1
        &:after
            display none
.b-content-round-item-title
    font-size 1.8rem
    line-height 2.8rem
    font-weight 600
    margin 4px 0 16px
    letter-spacing 0
    &.mb-4
        margin-bottom 4px

.b-lk-hello
    padding 16px 0 32px
.b-lk-hello-head1
    font-size 2.4rem
    line-height 125%
    font-weight 600
    letter-spacing -0.48px
    margin 0 0 4px
.b-lk-hello-head2
    font-size 1.6rem
    line-height 2.4rem
    font-weight 400
    margin 0
    letter-spacing 0
.b-lk-title
.redesign-version .popup-body h3
    font-size 1.8rem
    line-height 2.8rem
    font-weight 600
    margin 4px 0 16px
    letter-spacing 0
.b-lk-settings-list
    display flex
    flex-wrap wrap
    align-items stretch
    gap 8px
    &_item
        display block
        box-sizing border-box
        height 100%
        padding 16px
        background rgba(0, 0, 0, 0.04)
        border-radius 16px
        color #172419
    &_icon
        display block
        height 32px
        margin 0 0 12px
        .ph
            font-size 32px
        svg
            display block
    &_title
        display block
        font-size 1.6rem
        line-height 2.4rem
        font-weight 600
        margin 0 0 4px
    &_copy
        display block
        font-size 1.4rem
        line-height 2rem
        letter-spacing -0.28px
        color rgba(23, 36, 25, 0.72)
    li
        width calc(50% - 4px)

.schedule-table
    table-layout auto
    thead
        th
            padding-top 0
    th
        padding 0 2px 4px
        font-size 1.4rem
        line-height 2rem
        letter-spacing -0.28px
        text-transform capitalize
        color #172419
        .sch-tbl-inn
            height 32px
            align-items center
            justify-content center
        .day
            font-size 1.4rem
            line-height 2rem
            letter-spacing -0.28px
        &.weekend
            color #E63532
    td
        padding 0 2px 4px
        color #172419
        &.no-day
            .sch-tbl-inn
                background none
        &.full
            .sch-tbl-inn
                background #E8F4EA
        &.today
            .sch-tbl-inn
                border-color #148F2B
        &.weekend
            .sch-tbl-day-numb
                color #E63532
            .sch-tbl-inn.editable
                .sch-tbl-day-numb
                    color #083911
        .sch-tbl-inn
            &.editable
                background rgba(18, 129, 39, 0.40)
                border 1px solid rrgba(18, 129, 39, 0.40)
                position relative
                &:after
                    display block
                    content ""
                    width 16px
                    height 16px
                    background url("data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAA8AAAALCAQAAAAKTh/XAAAAOUlEQVR42n3NsREAIAjAQDeHzRwtNtLkADvvA5zpEUBsCKxIrqgbzeT/xLCWrMDo4AoVCBUIHXT4AO51ekdAbwlnAAAAAElFTkSuQmCC") 50% 50% no-repeat #148F2B
                    background-size 8px 6px
                    border-radius 50%
                    position absolute
                    bottom -1px
                    right -1px
    .sch-tbl-inn
        width 100%
        height 72px
        align-items flex-start
        justify-content flex-start
        border 1px solid transparent
        padding 4px
    .sch-tbl-day-numb
        display block
        width 20px
        height 20px
        margin 2px 2px 6px
        font-size 1.4rem
        line-height 2rem
        letter-spacing -0.28px
        align-self flex-start
    .sch-tbl-time-start
    .sch-tbl-time-end
        margin 0 0 0 4px

.sch-edit-btn
    position fixed
    bottom 0
    z-index 12
    height 74px
    padding 8px 0 0
.btns-block
    display flex
    gap 4px
    .btn
        width auto
        min-width 120px
        &:last-child
            flex-grow 1

.work-time
    box-sizing border-box
    position relative
    min-height 52px
    padding 0
    background rgba(0, 0, 0, 0.04)
    border-radius 8px
    border 1px solid transparent
    &__label
        font-size 1.6rem
        line-height 2.4rem
        color #172419
        position absolute
        top 14px
        left 16px
        transition all 175ms
        pointer-events none
    &__fields
        display flex
        justify-content space-between
        padding 0 16px
    &__group
        display flex
        align-items center
        width calc(50% - 3px)
        gap 6px
        opacity 0
        visibility hidden
        pointer-events none
        transition .2s ease
    &__text
        font 1.6rem $inter
        color #172419
    &__input
        border none
        background transparent
        outline none
        font 1.6rem/2.4rem $inter
        color #172419
        padding 0
        appearance none
        -webkit-appearance none
.work-time:focus-within
    border-color rgba(18, 129, 39, 0.40)
    .work-time__label
        top 4px
        transform translateY(0)
        font-size 1.2rem
        line-height 1.8rem
        color #128127
    .work-time__group
        opacity 1
        visibility visible
        pointer-events auto
        margin-top 22px
.work-time:has(.work-time__input:valid)
    .work-time__label
        top 4px
        transform translateY(0)
        font-size 1.2rem
        line-height 1.8rem
    .work-time__group
        opacity 1
        visibility visible
        pointer-events auto
        margin-top 22px

.head-tabs-wrap
    padding 16px 0
.head-tabs
    background #D0E9D5
    li
        color #172419
        &.active
            border-color #fff
            color #172419

.head-top
    h1.fw-600
        font-weight 600
    .head-period
    .today
        font-size 1.4rem
        line-height 2rem
        font-weight 500
        letter-spacing -0.28px
        color #128127
        margin-left 16px
    .head-top-icon
        color #148F2B



.h-calendar-inner .ui-widget.ui-widget-content {
    border: none;
}
.h-calendar-inner .ui-datepicker .ui-datepicker-header {
    margin-bottom: 15px;
}
.h-calendar-inner .ui-datepicker .ui-datepicker-next,
.h-calendar-inner .ui-datepicker .ui-datepicker-prev {
    background: none;
    margin-top: 0;
}
.h-calendar-inner .ui-datepicker .ui-datepicker-prev {
    transform: none;
}
.h-calendar-inner .ui-state-default, .ui-widget-content .ui-state-default {
    background: rgba(0, 0, 0, .04);
    border-radius: 16px;
    border: 1px solid transparent;
    padding: 0;
    text-align: center;
}
.h-calendar-inner .ui-datepicker .ui-datepicker-title {
    color: #128127;
}
#select_date .h-calendar-inner .ui-datepicker .ui-state-active {
    background: #148F2B;
    color: #fff;
}
.h-calendar-inner .ui-widget-content .ui-state-highlight {
    border-color: transparent;
}
html
	font-size 62.5%
	-webkit-font-smoothing antialiased
	height 100%

body
	font 1.4rem/1.8rem $sfProDisplay
	color #1F1F1F
	background #fff
	height 100%

.clear
	clearfix()

a
	color #0190DB
	text-decoration none

.btn
	display block
	box-sizing border-box
	width 100%
	background #0190DB
	border-radius 8px
	font-weight 600
	font-size 1.6rem
	line-height 2rem
	padding 16px
	color #fff
	text-align center
	&:disabled
		opacity 0.48
		cursor default
	&.white
		background #fff
		color #0190DB
		.phone
			font-size 1.4rem
			line-height 2rem
			font-weight 500
			color #1f1f1f
			display block
	&.white2
		background #fff
		font-weight 600
		color #1F1F1F
	&.green
		background #2B9927
		color #fff
	&.white-border
		border 1px solid rgba(1, 144, 219, 0.48)
		background #fff
		color #0190DB
		font-size 1.4rem
		line-height 2rem
		font-weight 400
		color #1f1f1f
	&.white-border-bigf
		border 1px solid rgba(1, 144, 219, 0.48)
		background #fff
		color #0190DB
		color #1f1f1f
	&.white-small
		background #fff
		color #8f8f8f
		font-size 1.4rem
		line-height 2rem
		font-weight 400
		padding-top 8px
		padding-bottom 8px
	&.small-btn
		height 40px
		padding 10px
		background none
		border 1px solid rgba(1, 144, 219, 0.48)
		font-size 1.4rem
		line-height 2rem
		font-weight 400
		color #1f1f1f
		display flex
		align-items center
		justify-content center
		i
			font-size 2rem
			margin 0 12px 0 0
		i.ph-arrow-right
			margin 0 0 0 12px
	&.big-font
		font-size 1.6rem
		font-weight 600

button.btn
	border none
	margin 0
	font-family 'SF Pro Display',Helvetica,Arial,sans-serif


.h-wrapper
	padding 0 0 68px
	&.fixed-height
		height 100%
		padding 0
		.h-content-wrap
			height calc(100% - 132px)
		.schedule-wrap
			box-sizing border-box
			height 100%

.h-fixed
	padding 0 16px


.h-header
	background #fff
	box-shadow 0px 10px 20px rgba(0, 0, 0, 0.04), 0px 2px 6px rgba(0, 0, 0, 0.04), 0px 0px 1px rgba(0, 0, 0, 0.04)
	border-radius 0px 0px 12px 12px
	position relative
	z-index 5
	&.header-sticky
		position sticky
		top 0
	&.head-top-dots-popup__opened
		z-index 21
	&.head-search-autosuggest-popup__opened
		z-index 21

.head-top
	box-sizing border-box
	min-height 64px
	padding 10px 0
	display flex
	align-items center
	h1
		fz(h1)
		text-overflow ellipsis
		white-space nowrap
		overflow hidden
		max-width calc(100% - 40px)
		.ph-caret-left
			font-size 3.2rem
			margin 0 16px 0 0
			vertical-align middle
	.today
	.head-period
		font-weight 600
		color #006fbc
		margin 0 0 0 8px
		
	.head-top-icon
		margin 0 4px 0 auto
		font-size 2.8rem
		color #0190DB
		&.div-block
			margin-right -8px
			display flex
			align-items center
			color #5C5C5C
			a.head-top-icon-users
			a.head-top-icon-list
			a.head-top-icon-magnifying
				color #5C5C5C
				margin 0 0 0 8px
			a.head-top-icon-magnifying2
				color #5C5C5C
				margin 0 16px 0 0
			a.head-top-icon-plus
				margin 0 8px
			a.head-top-icon-qrcode
			span.head-top-icon-qrcode
				color #5C5C5C
				margin 0 8px 0 16px
				&.disabled
					opacity .48
			a.head-top-icon-filter
				color #5C5C5C
				margin 0 8px
				position relative
				&.chosen
					&:after
						display block
						content ""
						width 8px
						height 8px
						background #0190DB
						border-radius 50%
						position absolute
						top -4px
						right -4px
		&.head-top-icon-brand
			color #5C5C5C
		.head-period
			font-size 1.4rem
			line-height 2rem
			font-weight 600
			margin 0 16px 0 0
	.head-top-dots-popup-wrap
		margin-left 8px
		.ph-dots-three-vertical
			cursor pointer
			position relative
			z-index 2
	.head-top-dots-popup
		position fixed
		top 0
		right 0
		z-index 20
		box-sizing border-box
		width 100%
		height 100%
		padding 16px 8px
		background #FFFFFF
		box-shadow 0px 10px 20px rgba(0, 0, 0, 0.04), 0px 2px 6px rgba(0, 0, 0, 0.04), 0px 0px 1px rgba(0, 0, 0, 0.04)
		border-radius 12px 12px 0 0
		font-size 1.6rem
		line-height 2.4rem
		color #1f1f1f
		display none
		&.var2
			padding 32px 0 0
			background none
			&:before
				display block
				content ""
				width 100%
				height 100%
				background rgba(0,0,0,.4)
				position absolute
				top 0
				left 0
				z-index -1
			.head-top-dots-popup__inner
				box-sizing border-box
				background #FFFFFF
				box-shadow 0px 10px 20px rgba(0, 0, 0, 0.04), 0px 2px 6px rgba(0, 0, 0, 0.04), 0px 0px 1px rgba(0, 0, 0, 0.04)
				border-radius 12px 12px 0 0
				padding 8px 0
				width 100%
				max-height 100%
				overflow-y auto
				position absolute
				bottom 0
				left 0
				.head-top-dots-popup__closer
					position absolute
					top 17px
					right 16px
					.ph-x
						font-size 30px
						color #5c5c5c

		h4
			font-size 2rem
			line-height 2.4rem
			font-weight 500
			margin 0 0 4px
			padding 12px 16px
		.dots-popup-list-choose
			li
				margin 0 0 4px
				.head-tabs
					margin-left 16px
					flex 1
					li
						margin 0
			a
				display block
				padding 12px 16px
				color #1f1f1f
				position relative
			.dots-popup-list-spfl
				display flex
				align-items center
			.ph-check-bold
				position absolute
				top 50%
				right 16px
				transform translateY(-50%)
				color #0190DB
				opacity 0
			li.active
				a
					background rgba(1, 144, 219, 0.08)
					border-radius 2px
				.ph-check-bold
					opacity 1
				.head-tabs
					margin-right 32px
			li.separate
				border-top 1px solid rgba(0, 0, 0, 0.16)
				margin-top 16px
				padding-top 16px

.head-dop
	padding 8px 0
	&.w-padding
		position relative
		padding-right 48px
		.head-top-icon
			font-size 2.8rem
			color #0190DB
			position absolute
			top 50%
			right 0
			transform translateY(-50%)
		.head-tabs span.year
			display block
	&.in-body
		padding-top 24px

ul.head-dop-nav
	li
		margin 0
		font-size 1.6rem
		line-height 2.4rem
	a
		display block
		color #5c5c5c
		font-size 1.6rem
		line-height 2.4rem
		padding 8px 24px 8px 0
		position relative
		.ph-caret-right
			display inline-flex
			position absolute
			top 50%
			right 0
			transform translateY(-50%)
			font-size 1.6rem

.head-dop-period
	min-height 52px
	font-size 1.6rem
	line-height 2.4rem
	color #5C5C5C
	display flex
	align-items center

.trans-btns
	display flex
	justify-content space-between
	li
		box-sizing border-box
		width 33.3%
		padding 0 4px
		font-size 1.6rem
		line-height 2.4rem
		font-weight 600
		&:first-child
			padding-left 0
		&:last-child
			padding-right 0

.head-tabs-title
	font-size 1.2rem
	line-height 1.6rem
	color #8F8F8F
	margin -20px 0 4px
.head-tabs
	background rgba(1, 144, 219, 0.12)
	border-radius 8px
	padding 4px
	display flex
	align-items center
	justify-content space-between
	&.w50 li
		width 50%
	&.w33 li
		width 33.3%
	li
		box-sizing border-box
		width 64px
		height 44px
		padding 4px 0
		color #5C5C5C
		text-align center
		display flex
		justify-content space-around
		flex-direction column
		&.active
			background #ffffff
			border 1px solid rgba(1, 144, 219, 0.32)
			border-radius 8px
			color #006FBC
			.year
				display block
	span
		display block
		&.day
			font-size 1.4rem
			line-height 2rem
		&.year
			display none
			font-size 1.2rem
			line-height 1.6rem

.head-tabs-popup-wrap
	padding 24px 0


.schedule-wrap
	overflow auto
	padding 0 0 68px

.schedule-table
	margin 0
	padding 0
	min-width 100%
	border-collapse collapse
	white-space nowrap
	table-layout fixed
	thead th
		position sticky
		top 0
		z-index 1
		background #fff
		padding-top 16px
		&.fixed
			z-index 3
	th
	td
		
		padding 0 2px 24px
		text-align center
		vertical-align top
		&.fixed
			position sticky
			left 0
			z-index 2
			padding-right 6px
			padding-left 8px
			background #fff
			font-size 1.2rem
			line-height 1.6rem
	th
		font-size 1.4rem
		font-weight 400
		line-height 1.8rem
		color #5C5C5C
		.day
			font-size 1.2rem
			line-height 1.6rem
		.ph-users-three
			font-size 3rem
	td
		font-size 1rem
		line-height 1.4rem
		color #5C5C5C
.sch-tbl-inn
	box-sizing border-box
	width 36px
	height 48px
	display flex
	flex-direction column
	align-items center
	justify-content center
	.schedule-table td &
		background rgba(0, 0, 0, 0.04)
		border-radius 8px
	.schedule-table td.full &
		background rgba(0, 0, 0, 0.08)
	.schedule-table .fixed &
		width 48px
		height 56px
		background #fff
	.schedule-table thead .fixed &
		height 40px
	.schedule-table td &.editable
		background rgba(1, 144, 219, 0.08)
		border 1px solid rgba(1, 144, 219, 0.48)
.sch-tbl-ava
	width 40px
	height 40px
	background #5C5C5C
	border-radius 8px
	font-size 1.4rem
	font-weight 400
	line-height 40px
	color #fff
	text-align center
	ellipsis()
	flex-shrink 0
	img
		display block
		width 40px
		height 40px
		border-radius 8px
.sch-tbl-date
	width 56px
	padding 10px 0 0
	font-size 1.4rem
	font-weight 400
	line-height 20px
	color #5C5C5C
	text-align center
	position sticky
	left 0
	z-index 3
	background #fff
	flex-shrink 0
	.day
		display block
		font-size 1.2rem
		line-height 1.6rem
.sch-tbl-name
	font-size 1.2rem
	font-weight 400
	line-height 1.6rem
	color #1F1F1F
	margin 2px 0 0
	ellipsis()
.sch-tbl-time-start
.sch-tbl-time-end
	margin 2px 0

.sch-edit-btn
	box-sizing border-box
	width 100%
	height 68px
	padding 6px 0 0
	background rgba(255, 255, 255, 0.8)
	backdrop-filter blur(4px)
	position fixed
	bottom 68px
	left 0
	z-index 2
	display none


.timetable-wrap
	padding 12px 0 0
	&__head
		padding 0 12px 12px 8px
		display flex
		align-items center
	.master-icon
		width 48px
		height 48px
		margin 0 8px 0 0
		text-align center
		line-height 48px
		color #5C5C5C
		.ph-users-three
			font-size 3rem
			vertical-align middle
	.master-copy
		font-size 1.6rem
		line-height 2rem
		font-weight 400
		display flex
		align-items center
		max-width calc(100% - 100px)
		.sch-tbl-ava
			width 40px
